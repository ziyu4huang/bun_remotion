        "text": "那些人還在前面打怪呢。算了，先去吃飯。"
      },
      {
        "character": "zhaoxiaoqi",
        "voice": "serena",
        "voiceDescription": {
          "voice": "serena",
          "gender": "female",
          "accent": "standard Mandarin, enthusiastic fanboy tone"
