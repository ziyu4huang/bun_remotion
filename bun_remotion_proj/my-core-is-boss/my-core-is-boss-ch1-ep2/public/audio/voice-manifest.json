      {
        "character": "linyi",
        "voice": "uncle_fu",
        "voiceDescription": {
          "voice": "uncle_fu",
          "gender": "male",
          "accent": "standard Mandarin, casual gamer tone"
        },
        "text": "啊，任務做完了。寶箱裡的東西還不錯。"
