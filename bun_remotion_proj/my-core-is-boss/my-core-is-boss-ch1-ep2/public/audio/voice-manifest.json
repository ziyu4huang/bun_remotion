      {
        "character": "zhaoxiaoqi",
        "voice": "serena",
        "voiceDescription": {
          "voice": "serena",
          "gender": "female",
          "accent": "standard Mandarin, enthusiastic fanboy tone"
        },
        "text": "師兄！你不去準備裝備嗎？大家都帶好了法器和丹藥！"
