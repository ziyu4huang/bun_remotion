      {
        "character": "linyi",
        "voice": "uncle_fu",
        "voiceDescription": {
          "voice": "uncle_fu",
          "gender": "male",
          "accent": "standard Mandarin, casual gamer tone"
        },
        "text": "不用不用，我找到了一條捷徑。"
      },
      {
        "character": "zhaoxiaoqi",
        "voice": "serena",
        "voiceDescription": {
          "voice": "serena",
          "gender": "female",
          "accent": "standard Mandarin, enthusiastic fanboy tone"
        },
        "text": "捷徑？！師兄是說……修行也有捷徑可走？"
      }
    ]
  },
  {
