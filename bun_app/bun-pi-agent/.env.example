# LLM Provider API Keys (at least one required)
ZAI_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# Default model (format: provider/model-name)
PI_AGENT_MODEL=zai/glm-5-turbo

# HTTP Server
PI_AGENT_HOST=127.0.0.1
PI_AGENT_PORT=3456

# Working directory for file/bash tools (default: current directory)
PI_AGENT_WORKDIR=
